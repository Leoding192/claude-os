# Agent skill runtime outputs
.agents/skills/codex/.runtime/
.agents/skills/docx/.runtime/
.agents/skills/pdf/.runtime/
.agents/skills/pptx/.runtime/
.agents/skills/xlsx/.runtime/

# All runtime logs (generated at runtime)
logs/

# Timestamped backups (generated by memory-slimmer.py)
backups/

# Session state (runtime-rewritten; template is memory/session.md.template)
memory/session.md

# Secrets
*.secret

# Python
__pycache__/
*.pyc

# OS
.DS_Store

# Secrets (never commit)
.env
.env.*

# Daily generated briefs (ephemeral, not version-controlled)
outbox/daily/*.md

# Second-brain inbox (temporary capture, not version-controlled)
second-brain/inbox/*
!second-brain/inbox/.gitkeep
